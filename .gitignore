cat << 'EOF' > .gitignore
# ==========================================
# 1. 核心大模型与权重文件 (绝对禁止上传)
# ==========================================
*.pt
best.pt
clip-model-offline/

# ==========================================
# 2. 敏感信息与本地配置
# ==========================================
.env
*.key

# ==========================================
# 3. 运行时的临时文件与日志
# ==========================================
*.jpg
*.jpeg
*.png
backend.log
nohup.out

# ==========================================
# 4. Python 缓存与虚拟环境
# ==========================================
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/

# ==========================================
# 5. IDE 与操作系统自动生成文件
# ==========================================
.vscode/
.idea/
.DS_Store
EOF